## Debug & Introspection

### Debug System Architecture

```mermaid
graph TB
    subgraph "Debug Exposure"
        WD[window.__msdDebug]
        API[window.cblcars.msd]
    end
    
    subgraph "Introspection Tools"
        PI[Pipeline Instance]
        SM[Systems Manager]
        DSM[DataSource Manager]
        RE[Rules Engine]
        AR[Advanced Renderer]
    end
    
    subgraph "Debug Renderers"
        DBG[MsdDebugRenderer<br/>Anchors, bounds, routing]
        CTRL[MsdControlsRenderer<br/>Interactive controls]
    end
    
    WD --> PI
    API --> PI
    PI --> SM
    SM --> DSM
    SM --> RE
    SM --> AR
    AR --> DBG
    AR --> CTRL
    
    style WD fill:#ff9900,stroke:#cc7700,stroke-width:2px
    style API fill:#ff9900,stroke:#cc7700,stroke-width:2px
```

### Debug Access Patterns

```javascript
// Access pipeline instance
const pipeline = window.__msdDebug.pipelineInstance;

// Inspect systems
const dsm = pipeline.systemsManager.dataSourceManager;
const rules = pipeline.systemsManager.rulesEngine;
const renderer = pipeline.systemsManager.renderer;

// Get data source values
const ds = dsm.getDataSource('cpu_usage');
console.log('Current:', ds.currentValue);
console.log('Buffer:', ds.buffer);
console.log('Stats:', ds.stats);

// Check rule matches
const matched = rules.getMatchedRules();
console.log('Active rules:', matched);

// Inspect overlays
const overlays = renderer.listOverlays();
console.log('Rendered overlays:', overlays);

// Get anchor positions
const anchor = pipeline.modelBuilder.getAnchor('button_1');
console.log('Anchor position:', anchor);

// Trigger manual re-render
window.cblcars.msd.reRender();

// Highlight overlays
window.cblcars.msd.highlight(['overlay_1', 'overlay_2'], { 
  color: '#ff0000', 
  duration: 2000 
});
```

